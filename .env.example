# Copy to .env.local and fill in.
# Endpoint for the contact form. Examples:
#   Formspree:    https://formspree.io/f/xxxxxxxx
#   Web3Forms:    https://api.web3forms.com/submit
#   Custom:       https://your.api/contact
# Leave unset to fall back to opening the user's mail client (mailto:).
VITE_FORMSPREE_ENDPOINT=
